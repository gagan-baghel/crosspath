# MongoDB Atlas connection string (Atlas clusters are replica sets, required by Prisma)
DATABASE_URL="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/relate?retryWrites=true&w=majority"

# Generate with: npx auth secret
AUTH_SECRET=""

# OPTIONAL. Ably API key (server-only; clients authenticate via /api/ably-token).
# Leave empty and chat still works via a polling fallback (~2.5s delivery).
# Set it to upgrade to instant delivery + typing indicators + online presence.
ABLY_API_KEY=""

NEXT_PUBLIC_APP_URL="http://localhost:3000"
